# DATABASE
POSTGRES_DB=fbr_leads
POSTGRES_USER=fbr_leads
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://fbr_leads:change-me@postgres:5432/fbr_leads
DATABASE_URL_ASYNCPG=postgresql://fbr_leads:change-me@postgres:5432/fbr_leads
REDIS_URL=redis://redis:6379/0

# LLM LAYER 1
OLLAMA_BASE_URL=http://100.64.0.10:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=15

# LLM LAYER 2
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=30

# LLM LAYER 3
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_SECONDS=30

# EXTERNAL INTEGRATIONS
ZEROBOUNCE_API_KEY=replace-me
APIFY_API_TOKEN=replace-me
FIRECRAWL_API_KEY=replace-me

# POSTAL
POSTAL_API_URL=https://postal.fbr.internal
POSTAL_API_KEY=replace-me
POSTAL_WEBHOOK_SECRET=replace-me
POSTAL_HOSTNAME=postal.fbr.internal
POSTAL_SMTP_PORT=25
POSTAL_HTTP_PORT=5000

# FBR-CLICK
FBR_CLICK_API_URL=https://fbr-click.com/api
FBR_CLICK_WEBHOOK_SECRET=replace-me
FBR_CLICK_CHANNEL_LEADS=chn_replace_me

# OPENCLAW
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:3500
OPENCLAW_WORKSPACE_ID=ws_replace_me

# DASHBOARD
SESSION_SECRET=replace-with-64-char-secret
BACKEND_URL=http://fastapi:8000
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost
DASHBOARD_EMAIL=owner@facebrasil.test
DASHBOARD_PASSWORD=change-me
DASHBOARD_USER_ID=owner-facebrasil
DASHBOARD_WORKSPACE_ID=10000000-0000-0000-0000-000000000001
FRONTEND_URL=http://frontend:3000

# NGINX / DOMAIN
APP_DOMAIN=leads.fbr.internal
TLS_CERT_PATH=/etc/letsencrypt/live/leads.fbr.internal/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/leads.fbr.internal/privkey.pem

# N8N
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678/
